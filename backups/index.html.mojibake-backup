        }

        .wrap {
            width: min(1120px, calc(100% - 32px));
            margin: 30px auto 46px;
        }

        .hero {
            background: linear-gradient(145deg, #0d1f38 0%, #22385e 72%);
            border-radius: 18px;
            padding: 34px;
            color: #f5f8ff;
            box-shadow: 0 18px 44px rgba(10, 19, 36, 0.26);
            animation: rise 0.55s ease-out;
        }

        .hero h1 {
            margin: 0;
            font-family: "Sora", sans-serif;
            font-size: clamp(1.75rem, 3vw, 2.45rem);
            letter-spacing: 0.01em;
        }

        .hero p {
            margin: 12px 0 18px;
            max-width: 840px;
            color: #d5e3fb;
            font-size: 1.05rem;
        }

        .hero-links {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 14px;
        }

        .hero-links a {
            text-decoration: none;
            color: #f8fbff;
            border: 1px solid rgba(255, 255, 255, 0.38);
            padding: 8px 14px;
            border-radius: 999px;
            transition: all 0.22s ease;
            font-size: 0.9rem;
        }

        .hero-links a:hover {
            color: #152b4c;
            background: #ffffff;
            transform: translateY(-2px);
        }

        .quick-facts {
            display: grid;
            gap: 10px;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            margin-top: 20px;
        }

        .fact {
            padding: 10px 12px;
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.18);
        }

        .fact strong {
            display: block;
            font-size: 1.06rem;
            color: #ffffff;
            line-height: 1.25;
        }

        .fact span {
            color: #d4def2;
            font-size: 0.85rem;
        }

        .section-title {
            margin: 32px 0 14px;
            font-family: "Sora", sans-serif;
            font-size: 1.45rem;
            color: #132742;
