            margin-top: 16px;
            display: grid;
            gap: 16px;
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .video-card {
            margin-top: 16px;
            border: 1px solid var(--line);
            border-radius: 14px;
            background: var(--surface);
            box-shadow: 0 8px 20px rgba(25, 39, 62, 0.06);
            overflow: hidden;
        }

        .video-card video {
