        .cert-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 14px 24px rgba(25, 39, 62, 0.14);
        }

        .cert-card a {
            text-decoration: none;
            color: inherit;
            display: block;
        }

        .cert-thumb {
            position: relative;
            height: 180px;
            background: linear-gradient(135deg, #eef3fb 0%, #e8edf7 100%);
            border-bottom: 1px solid #e4e9f2;
            overflow: hidden;
