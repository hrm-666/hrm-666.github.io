        .two-col {
            display: grid;
            gap: 14px;
            grid-template-columns: 1fr 1fr;
        }

        .panel {
            border: 1px solid var(--line);
            border-radius: 14px;
            background: var(--surface);
            padding: 16px;
            box-shadow: 0 8px 20px rgba(24, 41, 70, 0.06);
            animation: rise 0.6s ease-out;
