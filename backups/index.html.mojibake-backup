        .featured-head {
            padding: 18px 20px;
            background: linear-gradient(90deg, #ffe9df 0%, #fff5f0 100%);
            border-bottom: 1px solid #f6d8cb;
        }

        .badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 999px;
            background: var(--accent);
            color: #fff;
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.03em;
