            .gallery { grid-template-columns: repeat(2, minmax(0, 1fr)); }
            .cert-wall { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        }

        @media (max-width: 640px) {
            .quick-facts, .gallery { grid-template-columns: 1fr; }
