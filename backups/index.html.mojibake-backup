            font-size: 1.06rem;
            color: #122540;
            border-bottom: 1px solid #f1f5f9;
            padding-bottom: 8px;
        }

        .chips {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .chip {
            border-radius: 999px;
            background: #eef4ff;
            color: #123057;
            border: 1px solid #d5e3ff;
            padding: 6px 12px;
            font-size: 0.85rem;
        }

        .chip.hot {
            background: #fff0e8;
            border-color: #ffd8c4;
            color: var(--accent-strong);
        }

        .featured {
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 10px 26px rgba(24, 41, 70, 0.08);
