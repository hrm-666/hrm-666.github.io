            --line: #d8e1ee;
            --accent: #c2410c;
            --accent-strong: #9a3412;
            --deep: #0f1f36;
            --ok: #0f766e;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            color: var(--text);
            font-family: "Noto Sans SC", "Microsoft YaHei", sans-serif;
            line-height: 1.7;
