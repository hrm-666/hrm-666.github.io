            position: relative;
            min-height: 220px;
            border-radius: 12px;
            overflow: hidden;
            background: #e7edf6;
            border: 1px solid #dae4f2;
        }

        .thumb.small { min-height: 160px; }

        .thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform 0.5s ease;
        }

        .thumb:hover img { transform: scale(1.05); }

        .thumb-note {
            position: absolute;
            left: 10px;
            right: 10px;
            bottom: 10px;
            color: #f2f7ff;
            font-size: 0.84rem;
            padding: 8px 10px;
            border-radius: 8px;
            background: linear-gradient(90deg, rgba(8, 17, 32, 0.88), rgba(8, 17, 32, 0.46));
